# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mediflow:mediflow_dev_password@localhost:5432/mediflow
DATABASE_MAX_CONNECTIONS=20

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:mediflow_dev_password@localhost:6379

# ─── KAFKA ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=mediflow-service

# ─── AUTH SERVICE ────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ISSUER=https://auth.mediflow.io
JWT_AUDIENCE=https://api.mediflow.io
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── OBJECT STORAGE (MinIO) ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mediflow
MINIO_SECRET_KEY=mediflow_dev_password
MINIO_USE_SSL=false
MINIO_BUCKET_PRESCRIPTIONS=mediflow-prescriptions
MINIO_BUCKET_DOCUMENTS=mediflow-documents
MINIO_BUCKET_PROFILES=mediflow-profiles

# ─── ELASTICSEARCH ───────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_DRUGS=medications_v1
ELASTICSEARCH_INDEX_PHARMACIES=pharmacies_v1

# ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@mediflow.io
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ─── PAYMENTS ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYTABS_SERVER_KEY=your_paytabs_key
PAYTABS_PROFILE_ID=your_profile_id
FAWRY_MERCHANT_CODE=your_fawry_code
FAWRY_SECRET_KEY=your_fawry_secret

# ─── MAPS & GIS ──────────────────────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1IjoibWVkaWZsb3cifQ.xxx
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
OSRM_URL=http://localhost:5000

# ─── TELEMEDICINE ────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://livekit.mediflow.io
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── AI SERVICE ──────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8019
OPENAI_API_KEY=sk-xxx

# ─── MONITORING ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
PROMETHEUS_PORT=9090

# ─── FRONTEND (Next.js public vars) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:80/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8017
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoibWVkaWZsb3cifQ.xxx
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.mediflow.io
